# AI Provider (openai | ollama)
AI_PROVIDER=openai

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-replace-me
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Ollama (used when AI_PROVIDER=ollama)
OLLAMA_VISION_MODEL=llava
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Auth
JWT_SECRET_KEY=change-this-to-a-random-string-in-production

# Database
# Option A (preferred): full SQLAlchemy URL
DATABASE_URL=postgresql+asyncpg://shelfguard:shelfguard@localhost:5432/shelfguard

# Option B (used only when DATABASE_URL is missing)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shelfguard
POSTGRES_USER=shelfguard
POSTGRES_PASSWORD=shelfguard
SQLALCHEMY_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# App
LOG_LEVEL=INFO
MAX_IMAGE_SIZE_MB=10